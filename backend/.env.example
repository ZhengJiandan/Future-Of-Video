# Database
# 最小测试模式推荐直接使用 SQLite，不依赖本地 MySQL
DATABASE_URL=sqlite+aiosqlite:///./future_of_video.db
# 如需切回 MySQL，可改为：
# DATABASE_URL=mysql+aiomysql://user:password@127.0.0.1:3306/future_of_video

# Docker 最小模式示例：
# DATABASE_URL=sqlite+aiosqlite:///./uploads/future_of_video.db

# Security
JWT_SECRET_KEY=change-me-in-production
SECRET_KEY=change-me-in-production

# App runtime
ENVIRONMENT=development
DEBUG=false
MODEL_DEBUG_LOGGING=false
PIPELINE_RUNTIME_MODE=minimal
UPLOAD_DIR=./uploads
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
CELERY_RENDER_TASK_SOFT_TIME_LIMIT=3600
CELERY_RENDER_TASK_TIME_LIMIT=3900

# AI providers
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_BASE_URL=https://api-beijing.klingai.com
KLING_VIDEO_MODEL=kling-v3-omni
KLING_VIDEO_MODE=std

# 视频生成默认优先走可灵；当可灵 AK/SK 缺失时，auto 模式会自动降级到豆包
DOUBAO_API_KEY=
# 如果服务端未配置，也可以在前端本次会话里临时填写后再调用相关豆包能力
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-pro-260215
DOUBAO_IMAGE_BASE_URL=https://operator.las.cn-beijing.volces.com/api/v1
DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
DOUBAO_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
DOUBAO_READ_TIMEOUT=240
DOUBAO_SCRIPT_READ_TIMEOUT=360
DOUBAO_MAX_RETRIES=2
NANOBANANA_API_KEY=
NANOBANANA_BASE_URL=https://api.laozhang.ai/v1beta/models/gemini-3-pro-image-preview:generateContent

# Legacy project-level audio pipeline
# The old post-processing audio chain is currently disabled by default.
AUDIO_PIPELINE_ENABLED=false

# 环境设置
ENVIRONMENT=development

# 文件存储
UPLOAD_DIR=./uploads

# Redis 配置（可选）
# REDIS_URL=redis://localhost:6379/0

# Celery 配置（可选）
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
