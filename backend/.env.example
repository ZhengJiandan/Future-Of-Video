# Database
DATABASE_URL=mysql+aiomysql://user:password@127.0.0.1:3306/delta_force_video

# Security
JWT_SECRET_KEY=change-me-in-production
SECRET_KEY=change-me-in-production

# App runtime
ENVIRONMENT=development
DEBUG=true
PIPELINE_RUNTIME_MODE=full
UPLOAD_DIR=./uploads
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
CELERY_RENDER_TASK_SOFT_TIME_LIMIT=3600
CELERY_RENDER_TASK_TIME_LIMIT=3900

# AI providers
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-pro-260215
DOUBAO_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
DOUBAO_TTS_API_URL=https://openspeech.bytedance.com/api/v1/tts
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACCESS_TOKEN=
DOUBAO_TTS_CLUSTER=volcano_tts
DOUBAO_TTS_DEFAULT_VOICE_TYPE=zh_female_shaoergushi_mars_bigtts
DOUBAO_READ_TIMEOUT=240
DOUBAO_SCRIPT_READ_TIMEOUT=360
DOUBAO_MAX_RETRIES=2
NANOBANANA_API_KEY=
NANOBANANA_BASE_URL=https://api.laozhang.ai/v1beta/models/gemini-3-pro-image-preview:generateContent

# Audio pipeline
AUDIO_PIPELINE_ENABLED=true
AUDIO_TTS_PROVIDER=doubao-tts
AUDIO_SFX_PROVIDER=local-library
AUDIO_AMBIENCE_PROVIDER=local-library
AUDIO_MUSIC_PROVIDER=local-library
AUDIO_LIBRARY_ROOT=./uploads/generated/pipeline/audio_library
AUDIO_LIBRARY_MANIFEST=
AUDIO_SAMPLE_RATE=48000
AUDIO_CHANNELS=2
AUDIO_MASTER_CODEC=aac
AUDIO_MASTER_BITRATE=192k
